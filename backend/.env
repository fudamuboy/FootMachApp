# ==========================================
# BACKEND ENVIRONMENT VARIABLES (.env)
# ==========================================

# The port your Node.js server will run on
PORT=8000

# Your PostgreSQL Database Connection String
# LOCAL EXAMPLE: postgresql://postgres:password@localhost:5432/footmatch
# PRODUCTION EXAMPLE (e.g. from Supabase): postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/footmatch

# Secret Key for JSON Web Tokens (Authentication)
# Make sure to change this to a long random string in production!
JWT_SECRET=your_super_secret_jwt_key_here

# ==========================================
# FRONTEND ENVIRONMENT VARIABLES (.env)
# ==========================================

# Variables starting with EXPO_PUBLIC_ are automatically bundled into your React Native app.
# NEVER put secret keys (like database passwords) in this file!

# LOCAL TESTING: Put your local computer's IP address
EXPO_PUBLIC_API_URL=http://192.168.1.116:8000/api

# PRODUCTION: When building for the Play Store, change this to your deployed URL!
# EXPO_PUBLIC_API_URL=https://footmatch-api.onrender.com/api

{
  "expo": {
    "scheme": "myapp",
    "deepLinking": true,
    "name": "Dokuz On",
    "slug": "E-Sport",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/sport.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/logos.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.silmo.ESport"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/sport.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.silmo.ESport",
      "versionCode": 15,
      "permissions": [
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.606635332776-6u3e1ok8u2raq9motmai2oglchc9m666"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-5391073663429424~6516414875",
          "iosAppId": "ca-app-pub-5391073663429424~6516414875"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "88b549b4-b61a-4a24-bdb6-37237d5b0fbd"
      }
    }
  }
}
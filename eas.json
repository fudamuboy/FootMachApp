{
  "cli": {
    "version": ">= 16.17.4",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "macos-sequoia-xcode-26.0"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://footapp-backend.onrender.com/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}